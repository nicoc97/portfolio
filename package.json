{
  "name": "portfolio-site",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:performance": "vitest run --reporter=verbose src/test/performance.test.ts",
    "lighthouse": "node scripts/simple-lighthouse.cjs",
    "lighthouse:save": "node scripts/simple-lighthouse.cjs --save-report",
    "lighthouse:ci": "npm run build && npm run preview & sleep 5 && npm run lighthouse http://localhost:4173 --save-report && kill %1",
    "lighthouse:strict": "node scripts/simple-lighthouse.cjs --min-performance 95 --min-accessibility 95 --min-best-practices 95 --min-seo 95",
    "analyze": "npm run build && npx vite-bundle-analyzer dist"
  },
  "dependencies": {
    "@types/swiper": "^5.4.3",
    "@types/three": "^0.178.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "swiper": "^11.2.10",
    "three": "^0.178.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.10.5",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "autoprefixer": "^10.4.21",
    "chrome-launcher": "^1.1.2",
    "eslint": "^9.30.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "framer-motion": "^12.23.5",
    "globals": "^16.3.0",
    "jsdom": "^26.1.0",
    "lighthouse": "^12.2.1",
    "lucide-react": "^0.525.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.35.1",
    "vite": "^7.0.4",
    "vite-bundle-analyzer": "^0.11.1",
    "vitest": "^3.2.4"
  }
}
